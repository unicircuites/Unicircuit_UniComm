# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=unicomm_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT secret — change this to a long random string in production
JWT_SECRET=unicomm_super_secret_jwt_key_change_me_in_production

# Session idle timeout in milliseconds (default: 30 minutes = 1800000 ms)
# Users will be logged out after this period of inactivity
IDLE_TIMEOUT_MS=1800000

# Server
PORT=8088
# Listen on all interfaces so other PCs can open http(s)://TOWER_IP:PORT. Use 127.0.0.1 to disable LAN.
HOST=0.0.0.0
NODE_ENV=development

# CRM Integration Layer for agent access
# Preferred format: comma-separated agent_id:token pairs. Rotate every 90 days.
CRM_AGENT_TOKENS=lead_miner:q8tmwcfs2pgnijxe5ylr6o3hbzu4ka91,enrichment_agent:2hson6l4mzqr31x5ai08tbcvke7jpgwu
# Optional single-token fallback for local testing.
#CRM_AGENT_TOKEN=replace_with_long_random_token
#CRM_AGENT_ID=local_agent
# n8n webhook router URL for lead_created, lead_tier_changed, deal_stage_changed, customer_created.
CRM_N8N_WEBHOOK_URL=http://localhost:5678/webhook/crm-events
# Optional bearer token sent from CRM Integration Layer to n8n.
CRM_WEBHOOK_TOKEN=
CRM_WEBHOOK_TIMEOUT_MS=5000

# HTTPS (optional). When both are set, the app serves TLS on PORT (same port as HTTP would use).
# Use for LAN OAuth: Azure Web redirect https://192.168.0.205:8088/auth/callback
# Paths relative to backend/ or absolute. Self-signed example (OpenSSL), run inside backend/certs/:
#   openssl req -x509 -newkey rsa:4096 -keyout server.key -out server.crt -days 3650 -nodes -subj "/CN=192.168.0.205"
# Browsers will warn until you trust the cert (expected for private IP).
#SSL_KEY_PATH=certs/server.key
#SSL_CERT_PATH=certs/server.crt

# Browser-facing URL (no trailing slash) — must match how users open the site (same host:port as the address bar).
# Dev PC:        http://localhost:8088
# Tower server:  http://192.168.0.205:8088
APP_PUBLIC_URL=http://localhost:8088

# Microsoft Graph / Outlook (App Registration → Overview + Certificates & secrets)
# Tenant ID: Microsoft Entra ID → Overview → "Tenant ID" (same as App reg → "Directory (tenant) ID").
# NOT Application (client) ID, NOT App "Object ID", NOT subscription ID.
# If AADSTS90002: wrong value. Discover from domain (replace domain):
#   https://login.microsoftonline.com/YOURDOMAIN.onmicrosoft.com/v2.0/.well-known/openid-configuration
#   → "issuer" contains …/TENANT-GUID/v2.0
# Or set MS_TENANT_ID=organizations (app must allow organizational accounts per App reg manifest).
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Exact redirect URI under App registration → Authentication → Web (not SPA for this Node backend).
# Add every URL you use — Azure allows multiple Web redirects, e.g.:
#   http://localhost:8088/auth/callback
#   http://192.168.0.205:8088/auth/callback
# Must match APP_PUBLIC_URL host + /auth/callback (same http vs https, port).
MS_REDIRECT_URI=http://localhost:8088/auth/callback
# Mailbox used for Graph “me/…” calls; login hint for OAuth
MS_USER_EMAIL=sales@example.com

# Matrix PBX / SMDR
PBX_HOST=192.168.0.81
SMDR_PORT=5000
CTI_PORT=5001
# Voicemail/VMS extensions — last-hop only, hidden from call log display.
# Comma-separated. 390 and 398 are common Matrix Eternity defaults.
VMS_EXTENSIONS=390

# ── Storage Custom Directories (OneDrive / External storage config) ──────────────────────────
# Change these paths to your OneDrive or other system/mount directory to save C: drive space.
# If unset, they default to directories within the backend folder.
# Example:
#   WA_MEDIA_DIR=D:\OneDrive\UniComm_Storage\wa_media
#   WA_BACKUPS_DIR=D:\OneDrive\UniComm_Storage\wa_backups
#   PBX_LOCAL_RECORDINGS_DIR=D:\OneDrive\UniComm_Storage\pbx_recordings
#   OUTLOOK_BACKUPS_DIR=D:\OneDrive\UniComm_Storage\outlook_backups
#   CALL_REPO_BACKUP_DIR=D:\OneDrive\UniComm_Storage\call_backups

# WhatsApp media & backup storage
# WA_MEDIA_DIR=
# WA_BACKUPS_DIR=

# PBX recordings sync storage (local destination)
# PBX_LOCAL_RECORDINGS_DIR=

# Outlook backups storage
# OUTLOOK_BACKUPS_DIR=

# Call logs repository backup storage
# CALL_REPO_BACKUP_DIR=
