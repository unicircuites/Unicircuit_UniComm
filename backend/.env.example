# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=unicomm_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT secret — change this to a long random string in production
JWT_SECRET=unicomm_super_secret_jwt_key_change_me_in_production

# Server — localhost dev (HTTP)
PORT=8088
HOST=0.0.0.0
NODE_ENV=development

# ── Tower server deploy (192.168.0.55 — HTTPS) ──────────────────────────────
# On tower, uncomment and set these instead of the localhost values above:
# SSL_KEY_PATH=certs/server.key
# SSL_CERT_PATH=certs/server.crt
# MS_REDIRECT_URI=https://192.168.0.55:8088/auth/callback
# APP_PUBLIC_URL=https://192.168.0.55:8088
# NODE_ENV=production
# Note: API_BASE in dashboard.html uses window.location.origin — auto-adapts to both servers.

# ── Matrix Eternity PBX ─────────────────────────────────────────────────────
# PBX_HOST must be the static IP of the Matrix Hardware (likely 192.168.0.81)
PBX_HOST=192.168.0.81
# SMDR_PORT is the port the PBX will CONNECT TO (Passive mode listener on Tower Server)
# IMPORTANT: Must match PBX SMDR Posting port (typically 5001 for SARVAM UCS)
SMDR_PORT=5001
# CTI_PORT is the port the CRM connects to on the PBX for Click-to-Dial
CTI_PORT=4000
PBX_RECORDINGS_DIR=C:\MatrixVMS\Voicemail_Backup

# Directory (tenant) ID = MS_TENANT_ID | Application (client) ID = MS_CLIENT_ID
MS_TENANT_ID=407ec761-e4ad-4d41-9ea4-6ae7fe391047
MS_CLIENT_ID=d6224f70-6728-4f68-93aa-75a91f4adaa8
MS_CLIENT_SECRET=nzF8Q~v7eZui9WgYylxIebCoD2hCjzWao6gDpazR
# Azure → Authentication → Web must include this exact URI for local testing:
MS_REDIRECT_URI=http://localhost:8088/auth/callback
MS_USER_EMAIL=sales@unicircuites.com
APP_PUBLIC_URL=http://localhost:8088

# ── EngageBay CRM ────────────────────────────────────────────────────────────
ENGAGEBAY_API_KEY=your_engagebay_api_key_here

# ── Email Broadcast SMTP ─────────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@unicircuites.live
SMTP_PASS=V&z7GfwMNy4pVm&
SMTP_FROM=noreply@unicircuites.live
SMTP_FROM_NAME=Unicircuit Engineering Services LLP

# ── AI Email Intelligence Assistant ──────────────────────────────────
AI_API_HOST=https://api.groq.com/openai/v1
AI_API_MODEL=llama-3.1-8b-instant
AI_FAST_MODEL=llama-3.1-8b-instant
AI_CURRENT_MODEL=groq/compound-mini
AI_API_KEY=
AI_TIMEOUT_MS=20000
AI_MAX_TOKENS=160
AI_ALLOW_OLLAMA_FALLBACK=false

# External AI fallback (disabled by default - keep false for zero cost)
AI_EXTERNAL_ENABLED=false
AI_EXTERNAL_PROVIDER=
AI_EXTERNAL_API_KEY=
AI_EXTERNAL_MODEL=

# AI Assistant feature configuration
AI_ASSISTANT_ENABLED=true
AI_ASSISTANT_MAX_EMAILS=500
AI_ASSISTANT_BATCH_SIZE=20
AI_ASSISTANT_RATE_LIMIT=10

# Outlook Lead Scrape (mail snapshots → leads table)
LEAD_SCRAPE_ENABLED=true
LEAD_SCRAPE_INTERVAL_MIN=5
LEAD_SCRAPE_MAX_EMAILS=50
LEAD_SCRAPE_SINCE_HOURS=72
LEAD_SCRAPE_MIN_CONFIDENCE=0.60
LEAD_SCRAPE_USE_AI=false

# CRM Integration Layer & n8n
CRM_AGENT_TOKENS=lead_miner:lm_123456,enrichment_agent:enrich_789012
CRM_N8N_WEBHOOK_URL=http://localhost:5678/webhook-test/crm-events
CRM_WEBHOOK_TIMEOUT_MS=5000

# ── Storage Custom Directories (OneDrive / External storage config) ──────────────────────────
# Change these paths to your OneDrive or other system/mount directory to save C: drive space.
# If unset, they default to directories within the backend folder.
# Example:
#   WA_MEDIA_DIR=D:\OneDrive\UniComm_Storage\wa_media
#   WA_BACKUPS_DIR=D:\OneDrive\UniComm_Storage\wa_backups
#   PBX_LOCAL_RECORDINGS_DIR=D:\OneDrive\UniComm_Storage\pbx_recordings
#   OUTLOOK_BACKUPS_DIR=D:\OneDrive\UniComm_Storage\outlook_backups
#   CALL_REPO_BACKUP_DIR=D:\OneDrive\UniComm_Storage\call_backups

# WhatsApp media & backup storage
# WA_MEDIA_DIR=
# WA_BACKUPS_DIR=

# PBX recordings sync storage (local destination)
# PBX_LOCAL_RECORDINGS_DIR=

# Outlook backups storage
# OUTLOOK_BACKUPS_DIR=

# Call logs repository backup storage
# CALL_REPO_BACKUP_DIR=
