# Dependencies
node_modules/
backend/node_modules/

# Environment variables — never commit secrets
backend/.env

# Local TLS keys (generate on tower; never commit)
backend/certs/*.key
backend/certs/*.pem

# WhatsApp auth session — sensitive keys, never commit
backend/wa_auth/

# WhatsApp media cache — large files, never commit
backend/wa_media/

# Temp files
wa_section.txt
email_section.txt

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
